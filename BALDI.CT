  <CheatEntries>
    <CheatEntry>
      <ID>769</ID>
      <Description>"→ Initialize Mono"</Description>
      <Options moHideChildren="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]

{$lua}
mono_initialize()
LaunchMonoDataCollector()
{$asm}


[DISABLE]


</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>773</ID>
          <Description>"Invincible"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>define(address,PlayerManager:Update)
define(bytes,55 48 8B EC 48 83 EC 30)
//Send@FearkessRevolution|Sintrix
[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,PlayerManager:Update)

label(code)
label(return)

newmem:
mov [rcx+75],1

code:
  push rbp
  mov rbp,rsp
  sub rsp,30
  jmp return

address:
  jmp newmem
  nop 3
return:

[DISABLE]

address:
  db bytes

dealloc(*)

</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>774</ID>
          <Description>"Stealth Mode"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>
define(address,PlayerManager:Update+1c)
define(bytes,48 8B C8 48 BA F0 F3 13 15 C0 02 00 00)

[ENABLE]
//Send@FearkessRevolution|Sintrix
assert(address,bytes)
alloc(newmem,$1000,PlayerManager:Update+1c)

label(code)
label(return)

newmem:
mov [rcx+76],1
code:
  mov rcx,rax
  mov rdx,000002C01513F3F0
  jmp return

address:
  jmp newmem
  nop 8
return:

[DISABLE]

address:
  db bytes


dealloc(*)

</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>777</ID>
          <Description>"Infinite Stamina"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>
define(address,PlayerMovement:StaminaUpdate)
define(bytes,55 48 8B EC 48 81 EC 80 00 00 00)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,PlayerMovement:StaminaUpdate)
//Send@Sintrix|FearlessRevolution
label(code)
label(return)

newmem:
mov [rcx+A0],(float)100
code:
  push rbp
  mov rbp,rsp
  sub rsp,00000080
  jmp return

address:
  jmp newmem
  nop 6
return:

[DISABLE]

address:
  db bytes


dealloc(*)

</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>778</ID>
          <Description>"Disable Baldi"</Description>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>define(address,Baldi:Update)
define(bytes,55 48 8B EC 48 83 EC 40)

[ENABLE]
//Send@Sintrix|FearlessRevolution
assert(address,bytes)
alloc(newmem,$1000,Baldi:Update)

label(code)
label(return)

newmem:
mov [rcx+153],1
mov [rcx+13c],(float)0

code:
  push rbp
  mov rbp,rsp
  sub rsp,40
  jmp return

address:
  jmp newmem
  nop 3
return:

[DISABLE]

address:
  db bytes


dealloc(*)

</AssemblerScript>
        </CheatEntry>
